# Copy this file to .env.local and fill in the values

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Site Config ─────────────────────────────────────────────────────────────
# Change to your domain once deployed
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BLOG_NAME=My Blog
NEXT_PUBLIC_BLOG_TAGLINE=Thoughts, stories and ideas
NEXT_PUBLIC_BLOG_DESCRIPTION=A personal blog about technology, life, and everything in between.
NEXT_PUBLIC_AUTHOR_NAME=Your Name
